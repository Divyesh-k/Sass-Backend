# Copy to .env for local development. Never commit the real .env file.

APP_ENV=development
PORT=8080

DATABASE_URL=postgres://postgres:postgres@localhost:5432/saas?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Generate a real one for anything beyond local dev: openssl rand -hex 32
JWT_SECRET=dev-only-insecure-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

RATE_LIMIT_RPS=10

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
